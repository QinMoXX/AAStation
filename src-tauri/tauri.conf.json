{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AAStation",
  "version": "0.7.4",
  "identifier": "com.aastation.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AAStation - API Proxy",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": true,
        "focus": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGODUwNTdGN0U2MUVGMwpSV1R6SHViM1YxRDRDd1FzQ1hHekNFTDI4OGtsbE5CbEpMNkROT0p3RktwcGNLQUl3MDE1bm1zZAo=",
      "endpoints": [
        "https://github.com/QinMoXX/AAStation/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
